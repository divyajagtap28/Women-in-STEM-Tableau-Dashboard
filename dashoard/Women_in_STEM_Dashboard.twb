    <worksheet name='Women Representation in Selected STEM Occupations (%)'>
      <layout-options>
        <caption>
          <formatted-text>
            <run fontcolor='#000000' fontname='Calibri' fontsize='8'>Biological Scientists have the highest female representation (46%), while Architecture &amp; Engineering has the lowest (16.5%), indicating unequal representation across STEM occupations.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Women Graduated (Project 1 data)' name='federated.1nrzhcg0vd5y8v1bg3v1w1dup3u5' />
