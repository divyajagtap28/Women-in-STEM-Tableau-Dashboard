            <column-instance column='[Occupation]' derivation='None' name='[none:Occupation:nk]' pivot='key' type='nominal' />
            <column-instance column='[Women (Percent of total employed)]' derivation='None' name='[none:Women (Percent of total employed):ok]' pivot='key' type='ordinal' />
            <column-instance column='[Women (Percent of total employed)]' derivation='Sum' name='[sum:Women (Percent of total employed):qk]' pivot='key' type='quantitative' />
