    <worksheet name='Trend of Women Graduating in STEM Fields (2000–2015)'>
      <layout-options>
        <caption>
          <formatted-text>
            <run fontcolor='#000000' fontname='Calibri' fontsize='8'>Women consistently graduate in higher numbers in Biological Sciences. Engineering and Computer Science continue to show comparatively lower female participation, with Computer Science declining over the years.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
